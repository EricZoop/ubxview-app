{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [{ "url": "http://**" }, { "url": "https://**" }]
    },
    {
      "identifier": "cors-fetch:allow-fetch",
      "allow": [{ "url": "http://**" }, { "url": "https://**" }]
    },
    "cors-fetch:default",
    "http:default"
  ]
}
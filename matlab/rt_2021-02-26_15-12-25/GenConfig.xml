        <VecZ>0.03</VecZ>
      </FixtureCoords>
      <FixtureToBody>
        <Heading>0</Heading>
        <Pitch>0</Pitch>
        <Roll>0</Roll>
      </FixtureToBody>
      <BodyCoords>
        <!-- body coordinates in fixture frame [m] -->

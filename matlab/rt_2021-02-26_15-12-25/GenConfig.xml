      <Enabled>1</Enabled>
      <VehicleToFixture>
        <Heading>-45</Heading>
        <Pitch>16</Pitch>
        <Roll>0</Roll>
      </VehicleToFixture>
      <FixtureCoords>
        <!-- fixture coordinates in vehicle frame [m] -->
        <VecX>-0.864</VecX>

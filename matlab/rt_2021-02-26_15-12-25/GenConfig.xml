<?xml version="1.0"?>
<!-- All angles are in degrees, altitudes are Ellipsoid height (WGS84) -->
<!-- Positive heading is N to E, positive roll is right side down -->
<Config Version="7" Revision="2">
  <General>
    <PlatformName>MHR_360_OTM_TALIN</PlatformName>
    <MaxCarrierFreqCalibDev>5000</MaxCarrierFreqCalibDev>
    <!-- KHz -->
    <HarmonizVelOffset>0</HarmonizVelOffset>
    <!-- m/s -->
    <MinTxAttenuation>6</MinTxAttenuation>
    <!-- dB -->
    <!-- <SoftRadarId>0</SoftRadarId> -->
    <SoftwareCornerTurn>0</SoftwareCornerTurn>
    <AnechoicChamberMode>0</AnechoicChamberMode>
    <AllowProcParamsDiff>0</AllowProcParamsDiff>
    <EnableRxAttWeighting>0</EnableRxAttWeighting>
    <EnableTxAttWeighting>0</EnableTxAttWeighting>
    <SensorsConfig>
      <GpsReceiverType>2</GpsReceiverType>
      <!-- 1/2 for Hemisphere/Ublox -->
      <GpsOnWindowsSide>0</GpsOnWindowsSide>
      <!-- 1/0 for Hemisphere/Ublox -->
      <GpsReceiverTransport>2</GpsReceiverTransport>
      <!-- 1/2 for comm. port Hemisphere/ IOLAN -->
      <InsType>1</InsType>
      <!-- 1/2/3 TALIN/EGI/FOG -->
      <ManualPosition>0</ManualPosition>
      <ManualPitchRoll>0</ManualPitchRoll>
      <ManualHeading>0</ManualHeading>
      <UseInclForF2bCalib>0</UseInclForF2bCalib>
    </SensorsConfig>
    <INS>
      <SensorDataRate>50</SensorDataRate>
    </INS>
    <Communication>
      <AllowDynIpAddrs>1</AllowDynIpAddrs>
      <EthAdapterNameRt>ie1g0</EthAdapterNameRt>
      <MasterIpAddressRt>192.168.170.1</MasterIpAddressRt>
      <!-- base IP 13-->
      <IpSubnetMaskRt>255.255.0.0</IpSubnetMaskRt>
      <IpOrigSubnetWin>192.168.0.0</IpOrigSubnetWin>
      <MasterIpAddressWin>192.168.120.1</MasterIpAddressWin>
      <!-- base IP 171-->
      <IpSubnetMaskWin>255.255.0.0</IpSubnetMaskWin>
      <LabServerIpAddress>192.168.10.20</LabServerIpAddress>
      <!-- <HostCommDownStandby>1</HostCommDownStandby> -->
      <!-- <HostSendTimeout>1</HostSendTimeout> -->
      <TracksReportPeriod>0.1</TracksReportPeriod>
      <TracksSendAssocPlots>0</TracksSendAssocPlots>
      <TracksReportIfAssocPlot>0</TracksReportIfAssocPlot>
    </Communication>
    <Ethernet2Serial>
      <E2sIpAddress>192.168.220.1</E2sIpAddress>
      <E2sDataPortBase>1006</E2sDataPortBase>
      <!-- <E2sAtCkChNumber>3</E2sAtCkChNumber> -->
      <E2sInsChNumber>0</E2sInsChNumber>
      <E2sUbxChNumber>2</E2sUbxChNumber>
      <E2sHemiChNumber>1</E2sHemiChNumber>
      <E2sIoCardChNumber>3</E2sIoCardChNumber>
    </Ethernet2Serial>
    <GPS>
      <UseLocalTime>1</UseLocalTime>
      <UseEllipsoidAltitude>1</UseEllipsoidAltitude>
      <!-- 1 / 0 for ellipsoid (WGS84) / geoid (MSL; EGM96) alt. -->
      <MinSatForOper>4</MinSatForOper>
      <MinSatForCalib>5</MinSatForCalib>
      <MaxHdopForCalib>3.1</MaxHdopForCalib>
      <MinSamplesForCalib>100</MinSamplesForCalib>
      <MaxDeviatHpos>20</MaxDeviatHpos>
      <MaxDeviatAlt>50</MaxDeviatAlt>
      <MaxDeviatHeading>2.5</MaxDeviatHeading>
      <!-- degrees -->
      <MaxDeviatPitchRoll>2.5</MaxDeviatPitchRoll>
      <!-- degrees -->
    </GPS>
    <Recording>
      <RecordingPath>S:\sessions</RecordingPath>
      <AutoStartRecording>0</AutoStartRecording>
      <!-- 1 to force rec. session start on startup -->
      <AutoCommLogRecording>1</AutoCommLogRecording>
      <!-- 1 to force comm. log recording at all times -->
      <CommLogSegmentSize>4</CommLogSegmentSize>
      <!-- MB; 0 means maximum supported segment size -->
      <RawDataRecBuffSize>60</RawDataRecBuffSize>
      <!-- MB (only applicable to FPGA raw data mode)  -->
      <EnableRawDataRec>0</EnableRawDataRec>
      <SelectiveRecording>
        <SeqName>Track1</SeqName>
        <SeqName>Track2</SeqName>
        <SeqName>Track3</SeqName>
        <SeqName>Prop1</SeqName>
        <SeqName>Prop2</SeqName>
        <SeqName>Prop3</SeqName>
      </SelectiveRecording>
      <MinSpaceForRawDataRec>100</MinSpaceForRawDataRec>
      <!-- MB -->
      <MinSpaceForCommLogRec>100</MinSpaceForCommLogRec>
      <!-- MB -->
      <ResetTrkStateOnRec>0</ResetTrkStateOnRec>
      <AutoCommLogDaySessions>1</AutoCommLogDaySessions>
      <!-- 1 to create a new session at the start of each day -->
    </Recording>
    <BuiltInTest>
      <CpuTempThresholdMin>-40</CpuTempThresholdMin>
      <CpuTempThresholdMax>80</CpuTempThresholdMax>
      <CarrierTempThresholdMin>-40</CarrierTempThresholdMin>
      <CarrierTempThresholdMax>80</CarrierTempThresholdMax>
      <FilterTempThresholdMin>-40</FilterTempThresholdMin>
      <FilterTempThresholdMax>80</FilterTempThresholdMax>
      <RfMatrixTempThresholdMin>-40</RfMatrixTempThresholdMin>
      <RfMatrixTempThresholdMax>80</RfMatrixTempThresholdMax>
      <CpuLoadThreshold>85</CpuLoadThreshold>
      <!-- percent -->
      <TxFaultSnrThreshold>1</TxFaultSnrThreshold>
      <!-- dB -->
    </BuiltInTest>
    <Debug>
      <ConsoleOnWindowsSide>0</ConsoleOnWindowsSide>
      <LogTgtsToConsole>0</LogTgtsToConsole>
      <TgtsLoggingPeriod>0.25</TgtsLoggingPeriod>
      <!-- seconds; 0 means default -->
      <LogCpuLoadToConsole>0</LogCpuLoadToConsole>
      <!-- 0/1/2/3 for none/RT only/EML only/both -->
      <DebugLoggingLevel>1</DebugLoggingLevel>
      <!-- 0/1/2/3 for crit_error/error/warning/info -->
      <RemoteAppDebug>0</RemoteAppDebug>
      <DebugNoRfMatrix>0</DebugNoRfMatrix>
      <SettingsEditEnabled>1</SettingsEditEnabled>
      <InteractiveMode>1</InteractiveMode>
      <StatusUpdatePeriod>0.5</StatusUpdatePeriod>
      <!-- seconds -->
    </Debug>
  </General>
  <LocationAndAttitude>
    <GeodLocation>
      <!-- vehicle location (or radar location if no vehicle) -->
      <Latitude>0</Latitude>
      <Longitude>0</Longitude>
      <Altitude>0</Altitude>
    </GeodLocation>
    <LllnToVehicle>
      <Heading>0</Heading>
      <Pitch>0</Pitch>
      <Roll>0</Roll>
    </LllnToVehicle>
    <Radar Id="0">
      <Enabled>1</Enabled>
      <VehicleToFixture>
        <Heading>45</Heading>
        <Pitch>16</Pitch>
        <Roll>0</Roll>
      </VehicleToFixture>
      <FixtureCoords>

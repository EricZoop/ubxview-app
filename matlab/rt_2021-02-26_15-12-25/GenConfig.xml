      <Enabled>1</Enabled>
      <VehicleToFixture>
        <Heading>-135</Heading>
        <Pitch>16</Pitch>
        <Roll>0</Roll>
      </VehicleToFixture>
      <FixtureCoords>
        <!-- fixture coordinates in vehicle frame [m] -->
        <VecX>-0.864</VecX>
        <VecY>-2.24</VecY>
        <VecZ>0.03</VecZ>
      </FixtureCoords>
      <FixtureToBody>
        <Heading>0</Heading>

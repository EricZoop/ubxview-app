        <VecZ>0</VecZ>
      </BodyCoords>
    </Radar>
  </LocationAndAttitude>
  <C2I>
    <!-- this is optional and is used to override the value provided by the tracker -->
    <!-- <C2I_TargetType>1</C2I_TargetType> -->
    <!-- these are optional and are used to override values calculated from proc. params -->
    <!-- <C2I_Radius>10000</C2I_Radius>  <C2I_Angle1>-45</C2I_Angle1>  <C2I_Angle2>45</C2I_Angle2> -->
  </C2I>
</Config>